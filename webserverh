import socket
import threading
import os
import time
from datetime import datetime, timezone
from email.utils import formatdate

class Server:
    """
    Multi-threaded HTTP Web Server
    Supports: GET, HEAD, persistent/non-persistent connection, cache control (304)
    """
    def __init__(self, host="127.0.0.1", port=8080):
        print("Initializing HTTP server...")
        self.host = host
        self.port = port
        self.web_root = "./web_root"
        self.log_lock = threading.Lock()
        
        # Create web_root directory and default files if not exist
        self.setup_web_root()
        
        self.setup_socket()
        print(f"Server is running on {self.host}:{self.port}")
        self.accept()

    def setup_web_root(self):
        """Create web_root directory and default test files"""
        if not os.path.exists(self.web_root):
            os.makedirs(self.web_root)
            # Create default index.html
            with open(os.path.join(self.web_root, "index.html"), "w", encoding="utf-8") as f:
                f.write("""<html>
<head><title>Test Page</title></head>
<body>
<h1>Welcome to Multi-thread Web Server</h1>
<p>This is a test page.</p>
<img src="test.jpg" alt="Test Image">
</body>
</html>""")
            # Create test text file
            with open(os.path.join(self.web_root, "test.txt"), "w", encoding="utf-8") as f:
                f.write("This is a test text file for the web server.")
            # Create a simple 1x1 pixel GIF for image testing
            # Simple 1x1 transparent GIF binary data
            gif_data = b'GIF89a\x01\x00\x01\x00\x80\x00\x00\xff\xff\xff\x00\x00\x00!\xf9\x04\x01\x00\x00\x00\x00,\x00\x00\x00\x00\x01\x00\x01\x00\x00\x02\x02D\x01\x00;'
            with open(os.path.join(self.web_root, "test.jpg"), "wb") as f:
                f.write(gif_data)
            print(f"Created default files in '{self.web_root}/'")

    def setup_socket(self):
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.socket.bind((self.host, self.port))
        self.socket.listen(5)

    def accept(self):
        while True:
            client, address = self.socket.accept()
            th = threading.Thread(target=self.handle_client, args=(client, address))
            th.daemon = True
            th.start()

    def handle_client(self, client, address):
        """Handle each client connection, support persistent connection"""
        client.settimeout(10)  # timeout 10 seconds
        keep_alive = True
        
        while keep_alive:
            try:
                request_data = client.recv(4096).decode('utf-8', errors='ignore')
            except socket.timeout:
                break
            except ConnectionResetError:
                break
            
            if not request_data:
                break
            
            print(f"Received request from {address}")
            method, path, version, request_headers = self.parse_request(request_data)
            
            # Handle invalid request
            if method is None:
                status_code, response = self.build_response(400, "Bad Request", version, request_headers)
                client.sendall(response)
                self.write_log(address, "invalid", status_code)
                break
            
            status_code, response = self.handle_method(method, path, version, request_headers)
            
            status_msg = {
                200: "OK",
                400: "Bad Request",
                403: "Forbidden",
                404: "Not Found",
                304: "Not Modified",
            }
            status_msg = status_msg.get(status_code, "Unknown")
            print(f"path: {path} | Status: {status_code} {status_msg}")
            
            try:
                client.sendall(response)
            except (BrokenPipeError, ConnectionResetError):
                break
            
            self.write_log(address, path, status_code)
            
            # Check for persistent connection
            conn_header = request_headers.get("Connection", "").lower()
            if conn_header == "close":
                keep_alive = False
            elif version == "HTTP/1.0" and conn_header != "keep-alive":
                keep_alive = False
        
        try:
            client.close()
        except:
            pass

    def parse_request(self, request):
        """Parse HTTP request, extract method, path, version and headers"""
        lines = request.split('\r\n')
        request_headers = {}
        
        if not lines:
            return None, None, None, request_headers
        
        first_line = lines[0].strip()
        parts = first_line.split()
        if len(parts) < 3:
            return None, None, None, request_headers
        
        method = parts[0]
        path = parts[1]
        version = parts[2]
        
        # Validate HTTP version
        if version not in ["HTTP/1.0", "HTTP/1.1"]:
            version = "HTTP/1.1"
        
        # Parse headers
        for line in lines[1:]:
            line = line.strip()
            if not line:
                continue
            if ':' not in line:
                continue
            key, value = line.split(':', 1)
            request_headers[key.strip()] = value.strip()
        
        return method, path, version, request_headers

    def handle_method(self, method, path, version, request_headers):
        """Route request to appropriate handler"""
        # Security check: path traversal attack (403 Forbidden)
        if path and (".." in path or path.startswith("/../")):
            return self.build_response(403, "Forbidden", version, request_headers)
        
        # Only support GET and HEAD methods
        if method not in ["GET", "HEAD"]:
            return self.build_response(400, "Bad Request", version, request_headers)

        if method == "GET":
            return self.get_request(path, version, request_headers, is_head=False)
        elif method == "HEAD":
            return self.get_request(path, version, request_headers, is_head=True)
        
        return self.build_response(400, "Bad Request", version, request_headers)

    def build_response(self, status_code, status_text, version, request_headers=None, 
                       response_headers=None, body=b''):
        """Build HTTP response message"""
        res = ResponseBuilder(version)
        res.set_status(status_code, status_text)
        
        # Add Date header
        res.add_header("Date", formatdate(time.time(), usegmt=True))
        
        # Handle Connection header negotiation
        if request_headers:
            conn = request_headers.get("Connection", "keep-alive" if version == "HTTP/1.1" else "close")
            res.add_header("Connection", conn)
        else:
            res.add_header("Connection", "close")
        
        # Add custom response headers
        if response_headers:
            for k, v in response_headers.items():
                res.add_header(k, v)
        
        res.set_body(body)
        return status_code, res.build()

    def get_request(self, path, version, request_headers, is_head=False):
        """Handle GET and HEAD requests"""
        # Default to index.html
        if path == "/":
            path = "/index.html"
        
        # Normalize path (remove query string if present)
        if '?' in path:
            path = path.split('?')[0]
        
        file_path = os.path.join(self.web_root, path.lstrip("/"))
        
        # Check if file exists (404 Not Found)
        if not os.path.exists(file_path):
            return self.build_response(404, "Not Found", version, request_headers)
        
        # Check if it's a file (not directory)
        if not os.path.isfile(file_path):
            return self.build_response(404, "Not Found", version, request_headers)
        
        # Determine Content-Type based on file extension
        content_type = self.get_content_type(file_path)
        content_length = os.path.getsize(file_path)
        
        # Get last modified time
        mtime = os.path.getmtime(file_path)
        last_modified = formatdate(mtime, usegmt=True)
        
        # Check If-Modified-Since (304 Not Modified)
        if_modified_since = request_headers.get("If-Modified-Since")
        if if_modified_since:
            try:
                # Parse the If-Modified-Since header
                ims_time = time.mktime(time.strptime(if_modified_since, '%a, %d %b %Y %H:%M:%S %Z'))
                if mtime <= ims_time:
                    response_headers = {
                        "Last-Modified": last_modified
                    }
                    return self.build_response(304, "Not Modified", version, 
                                               request_headers, response_headers)
            except (ValueError, TypeError):
                pass  # Invalid date format, ignore and proceed
        
        # Build response headers for 200 OK
        response_headers = {
            "Content-Type": content_type,
            "Content-Length": str(content_length),
            "Last-Modified": last_modified
        }
        
        # Read file body (only for GET, not for HEAD)
        if is_head:
            return self.build_response(200, "OK", version, request_headers, response_headers)
        else:
            body = self.read_file(file_path)
            return self.build_response(200, "OK", version, request_headers, response_headers, body)

    def get_content_type(self, file_path):
        """Return appropriate Content-Type based on file extension"""
        ext = os.path.splitext(file_path)[1].lower()
        mime_types = {
            '.html': 'text/html',
            '.htm': 'text/html',
            '.txt': 'text/plain',
            '.jpg': 'image/jpeg',
            '.jpeg': 'image/jpeg',
            '.png': 'image/png',
            '.gif': 'image/gif',
            '.css': 'text/css',
            '.js': 'application/javascript',
            '.ico': 'image/x-icon',
        }
        return mime_types.get(ext, 'application/octet-stream')

    def read_file(self, file_path):
        """Read binary content of a file"""
        with open(file_path, "rb") as f:
            return f.read()

    def write_log(self, address, path, status_code):
        """Write access log to file with thread safety"""
        ip = address[0]
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        log_message = f"{ip} - - [{timestamp}] \"GET {path}\" {status_code}\n"
        
        with self.log_lock:
            with open("request.log", "a", encoding="utf-8") as f:
                f.write(log_message)
        
        # Also print to console for monitoring
        print(log_message.strip())


class ResponseBuilder:
    """Helper class to build HTTP response messages"""
    
    def __init__(self, version="HTTP/1.1"):
        self.version = version
        self.status_line = ""
        self.headers = {}
        self.body = b""

    def set_status(self, code, reason):
        self.status_line = f"{self.version} {code} {reason}"

    def add_header(self, key, value):
        self.headers[key] = value

    def set_body(self, body_bytes):
        self.body = body_bytes

    def build(self):
        """Build the complete HTTP response as bytes"""
        response = self.status_line + "\r\n"
        for key, value in self.headers.items():
            response += f"{key}: {value}\r\n"
        response += "\r\n"
        return response.encode("utf-8") + self.body


